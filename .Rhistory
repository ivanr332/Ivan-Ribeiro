library(readr)
library(stringr)
# Leitura dos arquivos
chars_raw <- read_lines("https://byuistats.github.io/M335/data/randomletters.txt")
chars <- paste(chars_raw, collapse = "")
chars_num <- read_lines("https://byuistats.github.io/M335/data/randomletters_wnumbers.txt") |>
paste(collapse = "")
# Task 2 - letra a cada 1700 posições
positions <- seq(1, nchar(chars), by = 1700)
hidden_chars <- str_sub(chars, positions, positions)
hidden_text <- paste(hidden_chars, collapse = "")
hidden_quote <- str_extract(hidden_text, "[a-zA-Z .]+\\.")
cat("Hidden quote:\n")
cat(hidden_quote, "\n\n")
# Task 3 - números viram letras
numbers <- str_extract_all(chars_num, "\\d+")[[1]] |>
as.integer()
decoded_message <- paste(letters[numbers], collapse = "")
cat("Decoded message:\n")
cat(decoded_message, "\n\n")
# Task 4 - maior sequência de vogais
clean_letters <- str_remove_all(chars, "[ .]")
vowel_runs <- str_extract_all(clean_letters, "[aeiou]+")[[1]]
longest_vowel_run <- vowel_runs[which.max(str_length(vowel_runs))]
longest_vowel_length <- max(str_length(vowel_runs))
cat("Longest vowel sequence:\n")
cat(longest_vowel_run, "\n")
cat("Length:", longest_vowel_length, "\n")
nchar(chars)
substr(chars, 1, 10)
substr(chars, 1700, 1700)
substr(chars, 3400, 3400)
substr(chars, 5100, 5100)
for(by in c(1700, 1750, 1800, 1400, 1600, 1650)) {
positions <- seq(1, nchar(chars), by = by)
hidden_chars <- str_sub(chars, positions, positions)
hidden_text <- paste(hidden_chars, collapse = "")
cat("by =", by, "->", hidden_text, "\n")
}
# Testa diferentes posições de início
for(start in c(1, 2, 3, 4, 5)) {
positions <- seq(start, nchar(chars), by = 1700)
hidden_chars <- str_sub(chars, positions, positions)
hidden_text <- paste(hidden_chars, collapse = "")
cat("start =", start, "->", hidden_text, "\n")
}
{r}
library(readr)
library(stringr)
chars <- read_lines("https://byuistats.github.io/M335/data/randomletters.txt") |>
paste(collapse = "") |>
str_to_lower()
chars_num <- read_lines("https://byuistats.github.io/M335/data/randomletters_wnumbers.txt") |>
paste(collapse = "") |>
str_to_lower()
positions <- seq(1, nchar(chars), by = 1700)
hidden_chars <- str_sub(chars, positions, positions)
hidden_text <- paste(hidden_chars, collapse = "")
hidden_quote <- str_extract(hidden_text, "^[^.]*\\.")
cat("Hidden quote:\n")
cat(hidden_quote, "\n\n")
numbers <- str_extract_all(chars_num, "\\d+")[[1]] |>
as.integer()
decoded_message <- paste(letters[numbers], collapse = "")
cat("Decoded message:\n")
cat(decoded_message, "\n\n")
clean_letters <- str_remove_all(chars, "[ .]")
vowel_runs <- str_extract_all(clean_letters, "[aeiou]+")[[1]]
longest_vowel_run <- vowel_runs[which.max(str_length(vowel_runs))]
longest_vowel_length <- max(str_length(vowel_runs))
cat("Longest vowel sequence:\n")
cat(longest_vowel_run, "\n")
cat("Length:\n")
cat(longest_vowel_length, "\n")
# Testa todos os intervalos de 100 a 2000
for(by in seq(100, 2000, by = 50)) {
positions <- seq(1, nchar(chars), by = by)
hidden_chars <- str_sub(chars, positions, positions)
hidden_text <- paste(hidden_chars, collapse = "") |> str_to_lower()
# Procura padrão com vogais e consoantes (texto legível)
if(str_detect(hidden_text, "[aeiou]{1}[a-z]{1,3}[aeiou]{1}")) {
if(str_detect(hidden_text, "\\.")) {
cat("by =", by, "->", hidden_text, "\n")
}
}
}
bom <- bom %>%
mutate(book_title = fct_inorder(book_title))
library(tidyverse)
url <- "https://raw.githubusercontent.com/beandog/lds-scriptures/master/csv/lds-scriptures.csv"
df <- read_csv(url)
df <- df %>%
mutate(word_count = str_count(scripture_text, "\\S+"))
nt  <- df %>% filter(volume_title == "New Testament")
bom <- df %>% filter(volume_title == "Book of Mormon")
nt_avg  <- mean(nt$word_count, na.rm = TRUE)
bom_avg <- mean(bom$word_count, na.rm = TRUE)
cat("Average verse length (New Testament):", round(nt_avg, 2), "\n")
cat("Average verse length (Book of Mormon):", round(bom_avg, 2), "\n")
nt_jesus  <- sum(str_detect(nt$scripture_text,  regex("\\bJesus\\b", ignore_case = TRUE)), na.rm = TRUE)
bom_jesus <- sum(str_detect(bom$scripture_text, regex("\\bJesus\\b", ignore_case = TRUE)), na.rm = TRUE)
cat("Occurrences of 'Jesus' in the New Testament:", nt_jesus, "\n")
cat("Occurrences of 'Jesus' in the Book of Mormon:", bom_jesus, "\n")
ggplot(bom, aes(x = book_title, y = word_count)) +
geom_boxplot() +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(
title = "Distribution of Verse Word Counts by Book (Book of Mormon)",
x     = "Book",
y     = "Words per Verse"
)
