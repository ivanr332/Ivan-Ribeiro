knitr::opts_chunk$set(echo = TRUE, message = FALSE, warning = FALSE, error = TRUE)
library(tidyverse)
library(stringr)
library(readr)
scriptures <- read_csv("https://raw.githubusercontent.com/beandog/lds-scriptures/master/csv/lds-scriptures.csv")
bom <- scriptures %>%
filter(volume_title == "Book of Mormon")
savior_names <- read_rds("https://byuistats.github.io/M335/data/BoM_SaviorNames.rds")
bom_text <- bom %>%
pull(scripture_text) %>%
str_c(collapse = " ")
pattern <- savior_names %>%
pull(name) %>%
str_c(collapse = "|")
segments <- str_split(bom_text, pattern)[[1]]
words_between <- segments %>%
str_trim() %>%
str_count("\\S+")
avg_distance <- mean(words_between, na.rm = TRUE)
cat("Average words between Savior references:", round(avg_distance, 2), "\n")
ggplot(tibble(words_between), aes(x = words_between)) +
geom_histogram(bins = 60, fill = "lightgreen", color = "white") +
coord_cartesian(xlim = c(0, 1000)) +
theme_minimal() +
labs(
title    = "Distribution of Words Between References to the Savior",
subtitle = paste("Average words between references:", round(avg_distance, 2)),
x        = "Words Between Savior References",
y        = "Frequency"
)
