river_p <- st_transform(river_filtered, crs_target)
map <- ggplot() +
geom_sf(data = idaho_p, fill = "gray95", color = "black") +
geom_sf(data = river_p, color = "blue", linewidth = 0.8) +
geom_sf(data = dams_p, color = "brown", size = 1.5) +
geom_sf(data = wells_p, color = "darkgreen", size = 1) +
coord_sf(
xlim = st_bbox(idaho_p)[c("xmin", "xmax")],
ylim = st_bbox(idaho_p)[c("ymin", "ymax")],
expand = FALSE
) +
labs(
title = "Idaho Water System Features",
subtitle = "Large dams, high production wells, and major rivers"
) +
theme_minimal() +
theme(
panel.grid = element_blank()
)
wells_filtered <- wells %>%
filter(Production > 5000)
dams_filtered <- dams %>%
filter(SurfaceAre > 50)
river_filtered <- river %>%
filter(FEAT_NAME %in% c("Snake River", "Henrys Fork"))
idaho_outline <- idaho %>%
summarise()
crs_target <- 26911
idaho_p <- st_transform(idaho, crs_target)
wells_p <- st_transform(wells_filtered, crs_target)
dams_p <- st_transform(dams_filtered, crs_target)
river_p <- st_transform(river_filtered, crs_target)
map <- ggplot() +
geom_sf(data = idaho_p, fill = "gray95", color = "black") +
geom_sf(data = river_p, color = "blue", linewidth = 0.8) +
geom_sf(data = dams_p, color = "brown", size = 1.5) +
geom_sf(data = wells_p, color = "darkgreen", size = 1) +
coord_sf(
xlim = st_bbox(idaho_p)[c("xmin", "xmax")],
ylim = st_bbox(idaho_p)[c("ymin", "ymax")],
expand = FALSE
) +
labs(
title = "Idaho Water System Features",
subtitle = "Large dams, high production wells, and major rivers"
) +
theme_minimal() +
theme(
panel.grid = element_blank()
)
print(map)
library(tidyverse)
library(leaflet)
library(sf)
library(USAboundaries)
states <- us_states()
idaho <- states %>%
filter(name == "Idaho")
idaho <- st_transform(idaho, 4326)
set.seed(123)
points <- tibble(
lng = runif(20, -117, -111),
lat = runif(20, 42, 49),
type = sample(c("Well", "Dam"), 20, replace = TRUE),
name = paste(type, row_number())
)
library(tidyverse)
library(leaflet)
library(sf)
library(USAboundaries)
states <- us_states()
idaho <- states %>%
filter(name == "Idaho")
idaho <- st_transform(idaho, 4326)
set.seed(123)
points <- tibble(
lng  = runif(20, -117, -111),
lat  = runif(20, 42, 49),
type = sample(c("Well", "Dam"), 20, replace = TRUE)
) %>%
mutate(name = paste(type, row_number()))
wells <- points %>% filter(type == "Well")
dams  <- points %>% filter(type == "Dam")
well_icon <- makeAwesomeIcon(icon = "tint",   library = "fa", markerColor = "blue")
dam_icon  <- makeAwesomeIcon(icon = "water",  library = "fa", markerColor = "red")
leaflet() %>%
addProviderTiles(providers$Esri.WorldTopoMap, group = "Topo") %>%
addProviderTiles(providers$CartoDB.Positron,  group = "Light") %>%
setView(lng = -114.5, lat = 44.2, zoom = 6) %>%
addPolygons(
data        = idaho,
color       = "black",
weight      = 2,
fillOpacity = 0,
group       = "Idaho"
) %>%
addAwesomeMarkers(
data  = wells,
lng   = ~lng,
lat   = ~lat,
icon  = well_icon,
label = ~name,
popup = ~paste0("<b>", name, "</b><br>Type: Well"),
group = "Wells"
) %>%
addAwesomeMarkers(
data  = dams,
lng   = ~lng,
lat   = ~lat,
icon  = dam_icon,
label = ~name,
popup = ~paste0("<b>", name, "</b><br>Type: Dam"),
group = "Dams"
) %>%
addLayersControl(
baseGroups    = c("Topo", "Light"),       # trocar tile base
overlayGroups = c("Idaho", "Wells", "Dams"), # ligar/desligar camadas
options       = layersControlOptions(collapsed = FALSE)
) %>%
addLegend(
position = "bottomright",
colors   = c("blue", "red"),
labels   = c("Well", "Dam"),
title    = "Locations",
opacity  = 1
)
file_downloader <- function(path){
df <- tempfile()
uf <- tempfile()
download.file(path, destfile = df, mode = "wb")
unzip(df, exdir = uf)
outp <- read_sf(uf)
file_delete(df)
dir_delete(uf)
return(outp)
}
dams  <- file_downloader("https://byuistats.github.io/M335/data/Idaho_Dams.zip") %>% st_transform(4326)
wells <- file_downloader("https://byuistats.github.io/M335/data/Wells.zip")      %>% st_transform(4326)
water <- file_downloader("https://byuistats.github.io/M335/data/water.zip")      %>% st_transform(4326)
state <- file_downloader("https://byuistats.github.io/M335/data/shp.zip")
idaho <- state %>%
filter(StateName == "Idaho") %>%
st_transform(4326)
names(wells)
names(dams)
leaflet() %>%
addProviderTiles(providers$Esri.WorldTopoMap, group = "Topo") %>%
addProviderTiles(providers$CartoDB.Positron,  group = "Light") %>%
setView(lng = -114.5, lat = 44.2, zoom = 6) %>%
addPolygons(
data        = idaho,
color       = "black",
weight      = 2,
fillOpacity = 0,
group       = "Idaho"
) %>%
addPolylines(
data   = water,
color  = "steelblue",
weight = 1,
group  = "Rivers"
) %>%
addCircleMarkers(
data        = wells,
color       = "#2196f3",
radius      = 1,
stroke      = FALSE,
fillOpacity = 0.6,
label       = ~Owner,
group       = "Wells"
) %>%
addCircleMarkers(
data        = dams,
color       = "#ff9800",
radius      = 2,
stroke      = FALSE,
fillOpacity = 0.8,
label       = ~DamName,
group       = "Dams"
) %>%
addLayersControl(
baseGroups    = c("Topo", "Light"),
overlayGroups = c("Idaho", "Rivers", "Wells", "Dams"),
options       = layersControlOptions(collapsed = FALSE)
) %>%
addControl(
html = '
<div style="background:white; padding:8px 12px; border-radius:6px;
border:1px solid #ccc; font-size:13px; line-height:1.8;">
<b>Legend</b><br>
<span style="color:red;">&#9679;</span> Wells<br>
<span style="color:cyan; -webkit-text-stroke:1px gray;">&#9679;</span> Dams<br>
<span style="color:steelblue;">&#9644;</span> Rivers
</div>',
position = "bottomright"
)
