install.packages("rsconnect")
rsconnect::addServer("https://shiny.byui.edu", name = "shiny-byui")
rsconnect::connectUser(server = "shiny-byui")
library(readr)
library(stringr)
chars <- read_lines("https://byuistats.github.io/M335/data/randomletters.txt") |>
paste(collapse = "") |>
str_to_lower()
chars_num <- read_lines("https://byuistats.github.io/M335/data/randomletters_wnumbers.txt") |>
paste(collapse = "") |>
str_to_lower()
positions <- seq(1, nchar(chars), by = 1700)
hidden_chars <- str_sub(chars, positions, positions)
hidden_text <- paste(hidden_chars, collapse = "")
hidden_quote <- str_extract(hidden_text, "^[^.]*\\.")
cat("Hidden quote:\n")
cat(hidden_quote, "\n\n")
numbers <- str_extract_all(chars_num, "\\d+")[[1]] |>
as.integer()
decoded_message <- paste(letters[numbers], collapse = "")
cat("Decoded message:\n")
cat(decoded_message, "\n\n")
clean_letters <- str_remove_all(chars, "[ .]")
vowel_runs <- str_extract_all(clean_letters, "[aeiou]+")[[1]]
longest_vowel_run <- vowel_runs[which.max(str_length(vowel_runs))]
longest_vowel_length <- max(str_length(vowel_runs))
cat("Longest vowel sequence:\n")
cat(longest_vowel_run, "\n")
cat("Length:\n")
cat(longest_vowel_length, "\n")
